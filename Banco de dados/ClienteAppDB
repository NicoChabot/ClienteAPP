CREATE TABLE ESTADO (
    ID INT PRIMARY KEY IDENTITY,
    NOME VARCHAR(50),
    UF CHAR(2)
);

CREATE TABLE CIDADE (
    ID INT PRIMARY KEY IDENTITY,
    NOME VARCHAR(50),
    ESTADOID INT FOREIGN KEY REFERENCES ESTADO(ID)
);

CREATE TABLE CLIENTE (
    ID INT PRIMARY KEY IDENTITY,
    NOME VARCHAR(80),
    CEP CHAR(8),
    CPF_CNPJ VARCHAR(14),
    ENDERECO VARCHAR(100),
    NUMERO VARCHAR(20),
    COMPLEMENTO VARCHAR(60),
    BAIRRO VARCHAR(100),
    CIDADE INT FOREIGN KEY REFERENCES CIDADE(ID),
    DATANASCIMENTO DATE
);

CREATE INDEX IX_CLIENTE_NOME ON CLIENTE(NOME);
CREATE INDEX IX_CLIENTE_CPF_CNPJ ON CLIENTE(CPF_CNPJ);
CREATE INDEX IX_CLIENTE_CEP ON CLIENTE(CEP);

